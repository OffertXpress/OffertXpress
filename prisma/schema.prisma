generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                  String   @id @default(cuid())
  name                String
  orgNumber           String?
  address             String?
  zip                 String?
  city                String?
  phone               String?
  email               String?
  slogan              String?
  logoUrl             String?
  bankgiro            String?
  plusgiro            String?
  payTerms            Int      @default(30)
  invoiceFooter       String?
  defaultBillingRate  Int      @default(750)
  materialMarkup      Int      @default(20)
  onboardingDone      Boolean  @default(false)
  trialStarted        DateTime @default(now())
  plan                String   @default("trial")
  createdAt           DateTime @default(now())
  users               User[]
  projects            Project[]
  offers              Offer[]
  invoices            Invoice[]
  customers           Customer[]
}

model User {
  id                 String   @id @default(cuid())
  companyId          String
  name               String
  email              String   @unique
  passwordHash       String
  role               String   @default("EMPLOYEE")
  grossMonthlySalary Int?
  hoursPerMonth      Int      @default(168)
  createdAt          DateTime @default(now())
  company            Company  @relation(fields: [companyId], references: [id])
}

model Project {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  customer        String?
  address         String?
  status          String   @default("ACTIVE")
  revenue         Float    @default(0)
  cost            Float    @default(0)
  estimatedProfit Float    @default(0)
  createdAt       DateTime @default(now())
  company         Company  @relation(fields: [companyId], references: [id])
  offers          Offer[]
  receipts        Receipt[]
}

model Offer {
  id            String   @id @default(cuid())
  companyId     String
  projectId     String?
  projectName   String
  customer      String?
  address       String?
  status        String   @default("DRAFT")
  total         Float    @default(0)
  myRevenue     Float    @default(0)
  isATA         Boolean  @default(false)
  signature     String?
  createdAt     DateTime @default(now())
  company       Company  @relation(fields: [companyId], references: [id])
  project       Project? @relation(fields: [projectId], references: [id])
}

model Invoice {
  id            String   @id @default(cuid())
  companyId     String
  invoiceNumber String
  customer      String
  projectName   String?
  total         Float
  status        String   @default("UNPAID")
  invoiceDate   String
  dueDate       String
  paidAt        String?
  createdAt     DateTime @default(now())
  company       Company  @relation(fields: [companyId], references: [id])
}

model Customer {
  id        String   @id @default(cuid())
  companyId String
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id])
}

model Receipt {
  id          String   @id @default(cuid())
  projectId   String
  description String?
  amount      Float
  date        String
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id])
}